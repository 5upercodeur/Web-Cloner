    def get_extension(self, url, content_type):
        
        url_lower = url.lower()
        content_type = content_type.lower()
        
        # Extensions par URL
        extensions_map = {
            '.css': '.css', '.js': '.js', '.mjs': '.js',
            '.png': '.png', '.jpg': '.jpg', '.jpeg': '.jpg', '.jfif': '.jpg',
            '.gif': '.gif', '.svg': '.svg', '.webp': '.webp', '.ico': '.ico',
            '.woff2': '.woff2', '.woff': '.woff', '.ttf': '.ttf', '.eot': '.eot',
            '.otf': '.otf', '.mp4': '.mp4', '.mp3': '.mp3', '.pdf': '.pdf',
            '.xml': '.xml', '.json': '.json', '.txt': '.txt'
        }
        
        for ext, mapped in extensions_map.items():
            if url_lower.endswith(ext):
                return mapped
        
        # Par content-type
        if 'css' in content_type: return '.css'
        if 'javascript' in content_type or 'js' in content_type: return '.js'
        if 'png' in content_type: return '.png'
        if 'jpeg' in content_type or 'jpg' in content_type: return '.jpg'
        if 'gif' in content_type: return '.gif'
        if 'svg' in content_type: return '.svg'
        if 'webp' in content_type: return '.webp'
        if 'x-icon' in content_type or 'ico' in content_type: return '.ico'
        if 'woff2' in content_type: return '.woff2'
        if 'woff' in content_type: return '.woff'
        if 'ttf' in content_type: return '.ttf'
        if 'eot' in content_type: return '.eot'
        if 'otf' in content_type: return '.otf'
        if 'mp4' in content_type: return '.mp4'
        if 'mp3' in content_type: return '.mp3'
        if 'pdf' in content_type: return '.pdf'
        if 'xml' in content_type: return '.xml'
        if 'json' in content_type: return '.json'
        
        return '.bin'
    
    def get_folder(self, ext):
       
        folder_map = {
            '.css': 'css', '.js': 'js',
            '.png': 'images', '.jpg': 'images', '.jpeg': 'images', '.gif': 'images',
            '.svg': 'images', '.webp': 'images', '.ico': 'images',
            '.woff2': 'fonts', '.woff': 'fonts', '.ttf': 'fonts', '.eot': 'fonts', '.otf': 'fonts',
            '.mp4': 'videos', '.mp3': 'audios',
            '.pdf': 'docs', '.xml': 'data', '.json': 'data'
        }
        return folder_map.get(ext, 'assets')
    
    def download_asset(self, url, base_url, retry=2):
        
        if url in self.downloaded_urls:
            return self.asset_map.get(url)
        
        # Construit l'URL complète
        full_url = urljoin(base_url, url)
        full_url = full_url.split('#')[0].split('?')[0]
        
        for attempt in range(retry):
            try:
                response = self.session.get(full_url, timeout=15)
                if response.status_code != 200:
                    continue
                
                content_type = response.headers.get('content-type', '')
                ext = self.get_extension(full_url, content_type)
                folder = self.get_folder(ext)
                
                # Nom de fichier basé sur l'URL avec hash
                url_hash = hashlib.md5(full_url.encode()).hexdigest()[:12]
                filename = f"{url_hash}{ext}"
                local_path = os.path.join(folder, filename)
                full_path = os.path.join(self.output_dir, local_path)
                
                os.makedirs(os.path.dirname(full_path), exist_ok=True)
                
                with open(full_path, 'wb') as f:
                    f.write(response.content)
                
                self.downloaded_urls.add(url)
                self.asset_map[url] = local_path
                return local_path
                
            except Exception:
                continue
        
        return None
    
    def extract_all_assets(self, html, base_url):
        
        soup = BeautifulSoup(html, 'html.parser')
        asset_count = 0
        
        # 1. CSS (link rel="stylesheet")
        for tag in soup.find_all('link', rel='stylesheet'):
            href = tag.get('href')
            if href:
                local = self.download_asset(href, base_url)
                if local:
                    tag['href'] = local
                    asset_count += 1
        
        # 2. Preconnect et d'autres liens
        for tag in soup.find_all('link', href=True):
            href = tag.get('href')
            if href and any(x in href for x in ['.css', '.js', '.ico', '.png', '.jpg']):
                if tag.get('rel') not in ['stylesheet']:
                    local = self.download_asset(href, base_url)
                    if local:
                        tag['href'] = local
                        asset_count += 1
        
        # 3. JavaScript
        for tag in soup.find_all('script', src=True):
            src = tag.get('src')
            if src:
                local = self.download_asset(src, base_url)
                if local:
                    tag['src'] = local
                    asset_count += 1
        
        # 4. Images
        for tag in soup.find_all('img', src=True):
            src = tag.get('src')
            if src and not src.startswith('data:'):
                local = self.download_asset(src, base_url)
                if local:
                    tag['src'] = local
                    asset_count += 1
        
        # 5. Images srcset
        for tag in soup.find_all('img', srcset=True):
            srcset = tag.get('srcset')
            if srcset:
                new_srcset = []
                for part in srcset.split(','):
                    part = part.strip()
                    if part:
                        url_part = part.split()[0]
                        if not url_part.startswith('data:'):
                            local = self.download_asset(url_part, base_url)
                            if local:
                                rest = ' '.join(part.split()[1:]) if len(part.split()) > 1 else ''
                                new_srcset.append(f"{local} {rest}".strip())
                            else:
                                new_srcset.append(part)
                        else:
                            new_srcset.append(part)
                if new_srcset:
                    tag['srcset'] = ', '.join(new_srcset)
                    asset_count += 1
        
        # 6. Favicon et icônes
        for tag in soup.find_all('link', rel=['icon', 'shortcut icon', 'apple-touch-icon']):
            href = tag.get('href')
            if href:
                local = self.download_asset(href, base_url)
                if local:
                    tag['href'] = local
                    asset_count += 1
        
        # 7. Polices et backgrounds dans CSS
        url_pattern = re.compile(r'url\([\'"]?([^\'"\)]+)[\'"]?\)', re.IGNORECASE)
        
        def replace_url_in_style(match, base_url):
            font_url = match.group(1)
            if font_url and not font_url.startswith('data:') and not font_url.startswith('http'):
                local = self.download_asset(font_url, base_url)
                if local:
                    return f"url('{local}')"
            return match.group(0)
        
        # Dans les styles inline
        for tag in soup.find_all(style=True):
            if tag.get('style'):
                def replacer(m):
                    return replace_url_in_style(m, base_url)
                tag['style'] = url_pattern.sub(replacer, tag['style'])
        
        # Dans les balises style
        for tag in soup.find_all('style'):
            if tag.string:
                def replacer(m):
                    return replace_url_in_style(m, base_url)
                tag.string = url_pattern.sub(replacer, tag.string)
        
        # 8. Videos et audios
        for tag in soup.find_all(['video', 'audio'], src=True):
            src = tag.get('src')
            if src:
                local = self.download_asset(src, base_url)
                if local:
                    tag['src'] = local
                    asset_count += 1
        
        # 9. Source tags
        for tag in soup.find_all('source', src=True):
            src = tag.get('src')
            if src:
                local = self.download_asset(src, base_url)
                if local:
                    tag['src'] = local
                    asset_count += 1
        
        # 10. Object et embed
        for tag in soup.find_all(['object', 'embed'], src=True):
            src = tag.get('src')
            if src:
                local = self.download_asset(src, base_url)
                if local:
                    tag['src'] = local
                    asset_count += 1
        
        return str(soup), asset_count
    
